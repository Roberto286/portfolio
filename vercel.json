{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "chmod a+x build.sh && ./build.sh",
  "outputDirectory": "public",
  "functions": {
    "api/og.jsx": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/og",
      "dest": "/api/og.jsx"
    }
  ]
}
